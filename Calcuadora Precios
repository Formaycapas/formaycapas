<script>
const CONS_W = 120;
let matId=0, saveTimer=null, _precio=0, _dis=0;

// ── UTILS ─────────────────────────────────────────────────
const $=id=>document.getElementById(id);
function fmt(n){return n.toFixed(2).replace('.',',')+' €'}
function fmtP(n){return Math.round(n)+'%'}
function toast(m,d=2200){const t=$('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),d)}
function setSaved(s){const b=$('saveBadge');b.className='savebadge'+(s?' saved':'');$('saveTxt').textContent=s?'Guardado':'Guardando...'}

// ── MATERIALES ────────────────────────────────────────────
function addMat(n='',p=25,g=50){
  const id=matId++;
  const row=document.createElement('div');
  row.className='mat-row';row.id='mr-'+id;
  row.innerHTML=`
    <input type="text" class="mn" placeholder="Ej: PLA negro / Soporte soluble" value="${n}" oninput="calc()">
    <div class="iw"><input type="number" class="mp" value="${p}" min="0.1" step="0.5" oninput="calc()"><span class="u">€</span></div>
    <div class="iw"><input type="number" class="mg2" value="${g}" min="0.1" step="0.5" oninput="calc()"><span class="u">g</span></div>
    <button class="bdel" onclick="delMat('mr-${id}')" title="Eliminar">×</button>`;
  $('matList').appendChild(row);
  updDel();calc();
}
function delMat(id){
  const rows=document.querySelectorAll('.mat-row');
  if(rows.length<=1){toast('Debe haber al menos un material');return}
  const el=$(id);
  if(el){el.style.opacity='0';el.style.transform='translateX(8px)';el.style.transition='all .2s';
    setTimeout(()=>{el.remove();updDel();calc();},200)}
}
function updDel(){
  const rows=document.querySelectorAll('.mat-row');
  rows.forEach(r=>{const b=r.querySelector('.bdel');if(b)b.disabled=rows.length<=1});
}

// ── AVANZADO ──────────────────────────────────────────────
function toggleAdv(){
  const p=$('advPanel'),a=$('advArr');
  const open=p.style.display==='block';
  p.style.display=open?'none':'block';
  a.style.transform=open?'rotate(0deg)':'rotate(180deg)';
}

// ── CÁLCULO ───────────────────────────────────────────────
function calc(){
  // INPUTS
  const hImp  = parseFloat($('hImp').value)||0;
  const hDis  = parseFloat($('hDis').value)||0;
  const kWh   = parseFloat($('kWh').value)||0.20;
  const tarI  = parseFloat($('tarImp').value)||2;
  const tarD  = parseFloat($('tarDis').value)||8;
  const marP  = parseFloat($('margen').value)||50;
  const falP  = parseFloat($('fallos').value)||15;
  const equP  = parseFloat($('equipo').value)||8;

  const minE  = parseFloat($('minEnc').value)||5;

  // GASTOS BASE: filamento + luz
  let cFil=0;
  document.querySelectorAll('.mat-row').forEach(r=>{
    const p=parseFloat(r.querySelector('.mp').value)||0;
    const g=parseFloat(r.querySelector('.mg2').value)||0;
    cFil+=(p/1000)*g;
  });
  const cLuz   = hImp*(CONS_W/1000)*kWh;
  const cGas   = cFil+cLuz; // GASTOS REALES

  // SERVICIO DE IMPRESIÓN: tarifa por hora → beneficio
  const cServ  = hImp*tarI;               // servicio impresión → BENEFICIO (aparte)
  const cGasT  = cGas;                    // GASTOS REALES: solo fil+luz

  // SOBRE GASTOS REALES (solo fil+luz)
  const cFall  = cGasT*(falP/100);        // reserva desgaste 10%
  const cEquip = cGasT*(equP/100);        // fondo equipos
  // cAhorro se calcula más abajo (depende del beneficio bruto)
  // cRes se completa después de calcular cAhorro

  // BENEFICIO (3 partes separadas: diseño + servicio + margen)
  const cDis   = hDis*tarD;              // diseño: 100% beneficio directo
  let   cMarg  = cGasT*(marP/100);       // margen 40% sobre gastos reales

  // TECHO DE IMPRESIÓN: precio de impresión (sin diseño) no supera X veces el coste de fabricación
  const techoMul = parseFloat($('techo').value)||3;
  const costeFab = cGasT+cServ;
  const subImp   = cGasT+cFall+cEquip+cServ+cMarg;  // sin diseño ni ahorro
  const techoMax = costeFab*techoMul;
  let   techoAp  = false;
  if(subImp>techoMax){
    const cMargMax = Math.max(0, techoMax-cGasT-cFall-cEquip-cServ);
    cMarg = cMargMax;
    techoAp = true;
  }
  const cBenBruto = cDis+cServ+cMarg;    // beneficio bruto
  const ahoP      = parseFloat($('ahorroBen').value)||30;
  const cAhorro   = cBenBruto*(ahoP/100);  // se desvía a reservas
  const cBen      = cBenBruto-cAhorro;     // beneficio NETO (a tu bolsillo)

  const cRes   = cFall+cEquip+cAhorro;  // reservas totales (incluye ahorro)

  // PRECIO FINAL
  let total    = cGasT+cRes+cBen;
  const minAp  = total<minE&&minE>0;
  if(minAp) total=minE;
  $('avisoTecho').style.display = techoAp ? 'block' : 'none';

  // SUGERENCIA DE CANTIDAD: si diseño pesa demasiado, calcular nº unidades óptimo
  const umbral = parseFloat($('umbralDis').value)||40;
  const pctDis = total>0 ? (cDis/total)*100 : 0;
  if(cDis>0 && pctDis>umbral){
    // Buscar cuántas unidades hacen falta para que diseño baje a 25%
    // Cada unidad adicional añade el coste de impresión completo (sin diseño)
    const costeImpresion = cGasT+cRes+cMarg; // por unidad
    // Queremos: cDis / (n*costeImp + cDis) <= 25%
    // => cDis*0.75 <= n*costeImp*0.25
    // => n >= (3*cDis) / costeImp
    const nOptimo = Math.ceil((3*cDis) / costeImpresion);
    const totalN  = nOptimo*costeImpresion + cDis;
    const porPieza = totalN/nOptimo;
    $('avisoCantidad').innerHTML =
      `💡 El diseño pesa <strong>${Math.round(pctDis)}%</strong> del precio. Con <strong>${nOptimo} unidades</strong> el coste por pieza bajaría a <strong>${fmt(porPieza)}</strong> (total <strong>${fmt(totalN)}</strong>) — diseño amortizado.`;
    $('avisoCantidad').style.display = 'block';
  } else {
    $('avisoCantidad').style.display = 'none';
  }

  // Guardar para modal
  _precio=total; _dis=cDis;

  // INFO DINÁMICA
  $('infoTarImp').textContent=tarI.toFixed(2).replace('.',',')+' €/h';
  $('infoHImp').textContent=hImp+'h';
  $('infoServImp').textContent=fmt(cServ);
  $('matSub').textContent=fmt(cFil);

  // RESULTADO PRINCIPAL
  const pEl=$('pFinal');
  pEl.textContent=total<0.01?'—':total.toFixed(2).replace('.',',')+' €';
  pEl.className='p-final'+(minAp?' minimo':'');
  $('pSub').textContent=minAp
    ?`Mínimo aplicado · Gastos: ${fmt(cGasT)} · Beneficio calculado: ${fmt(cBen)}`
    :`Gastos: ${fmt(cGasT)} · Reservas: ${fmt(cRes)} · Beneficio: ${fmt(cBen)}`;

  $('bGasto').textContent=`Gastos: ${fmt(cGasT)}`;
  $('bReserva').textContent=`Reservas: ${fmt(cRes)}`;
  $('bBeneficio').textContent=`Beneficio: ${fmt(cBen)}`;
  $('bMin').style.display=minAp?'block':'none';
  $('avisoMin').style.display=minAp?'block':'none';
  $('pMin').textContent=fmt(cGasT+cRes);

  // CATEGORÍA GASTOS
  $('cGT').textContent=fmt(cGasT);
  $('cGP').textContent=total>0?fmtP((cGasT/total)*100):'';
  $('dFil').textContent=fmt(cFil);  $('pFil').textContent=total>0?fmtP((cFil/total)*100)+' del total':'';
  $('dLuz').textContent=fmt(cLuz);  $('pLuz').textContent=total>0?fmtP((cLuz/total)*100)+' del total':'';

  // CATEGORÍA RESERVAS
  $('cRT').textContent=fmt(cRes);
  $('cRP').textContent=total>0?fmtP((cRes/total)*100):'';
  $('dFall').textContent=fmt(cFall);  $('pFall').textContent=total>0?fmtP((cFall/total)*100)+' del total':'';
  $('dEquip').textContent=fmt(cEquip);$('pEquip').textContent=total>0?fmtP((cEquip/total)*100)+' del total':'';
  $('dAhorro').textContent=fmt(cAhorro);$('pAhorro').textContent=total>0?fmtP((cAhorro/total)*100)+' del total':'';

  // CATEGORÍA BENEFICIO
  $('cBT').textContent=fmt(cBenBruto);
  $('cBP').textContent=total>0?fmtP((cBenBruto/total)*100):'';
  $('dDis').textContent=fmt(cDis);  $('pDis').textContent=total>0?fmtP((cDis/total)*100)+' del total':'';
  $('dServ').textContent=fmt(cServ);$('pServ').textContent=total>0?fmtP((cServ/total)*100)+' del total':'';
  $('dMarg').textContent=fmt(cMarg);$('pMarg').textContent=total>0?fmtP((cMarg/total)*100)+' del total':'';
  $('benBruto').textContent=fmt(cBenBruto);
  $('benAhorroResta').textContent='− '+fmt(cAhorro);
  $('benNeto').textContent=fmt(cBen);

  // BARRAS
  if(total>0){
    [['bFil',cFil,'bpFil'],['bLuz',cLuz,'bpLuz'],['bServ',cServ,'bpServ'],
     ['bFall',cFall,'bpFall'],['bEquip',cEquip,'bpEquip'],
     ['bDis',cDis,'bpDis'],['bMarg',cMarg,'bpMarg']
    ].forEach(([bid,v,pid])=>{
      const pct=(v/total)*100;
      $(bid).style.width=pct+'%';
      $(pid).textContent=fmtP(pct)+'%';
    });
  }

  // AUTOGUARDAR
  clearTimeout(saveTimer);setSaved(false);
  saveTimer=setTimeout(()=>{guardar();setSaved(true);},800);
}

// ── PERSISTENCIA ──────────────────────────────────────────
function guardar(){
  try{
    const mats=[];
    document.querySelectorAll('.mat-row').forEach(r=>mats.push({
      n:r.querySelector('.mn').value,
      p:r.querySelector('.mp').value,
      g:r.querySelector('.mg2').value
    }));
    localStorage.setItem('fyc_v48',JSON.stringify({
      mats,
      hImp:$('hImp').value,hDis:$('hDis').value,
      kWh:$('kWh').value,tarImp:$('tarImp').value,tarDis:$('tarDis').value,
      margen:$('margen').value,fallos:$('fallos').value,equipo:$('equipo').value,
      minEnc:$('minEnc').value,
      techo:$('techo').value,umbralDis:$('umbralDis').value,ahorroBen:$('ahorroBen').value
    }));
  }catch(e){}
}
function cargar(){
  try{
    const raw=localStorage.getItem('fyc_v48');if(!raw)return false;
    const s=JSON.parse(raw);
    $('matList').innerHTML='';matId=0;
    if(s.mats?.length>0)s.mats.forEach(m=>addMat(m.n,parseFloat(m.p),parseFloat(m.g)));
    else addMat('PLA modelo',25,50);
    const set=(id,v)=>{if(v!==undefined&&$(id))$(id).value=v};
    set('hImp',s.hImp);set('hDis',s.hDis);set('kWh',s.kWh);
    set('tarImp',s.tarImp);set('tarDis',s.tarDis);
    set('minEnc',s.minEnc);
    if(s.techo){$('techo').value=s.techo;$('techoV').textContent=parseFloat(s.techo).toFixed(1)+'x'}
    if(s.umbralDis){$('umbralDis').value=s.umbralDis;$('umbralDisV').textContent=s.umbralDis+'%'}
    if(s.ahorroBen){$('ahorroBen').value=s.ahorroBen;$('ahorroBenV').textContent=s.ahorroBen+'%'}
    if(s.margen){$('margen').value=s.margen;$('margenV').textContent=s.margen+'%'}
    if(s.fallos){$('fallos').value=s.fallos;$('fallosV').textContent=s.fallos+'%'}
    if(s.equipo){$('equipo').value=s.equipo;$('equipoV').textContent=s.equipo+'%'}
    return true;
  }catch(e){return false}
}
function confirmReset(){if(confirm('¿Restablecer todos los valores por defecto?'))reset()}
function reset(){
  $('matList').innerHTML='';matId=0;addMat('PLA modelo',25,50);
  $('hImp').value=3;$('hDis').value=0;$('kWh').value=0.20;
  $('tarImp').value=1.50;$('tarDis').value=10.00;
  $('margen').value=30;$('margenV').textContent='30%';
  $('fallos').value=10;$('fallosV').textContent='10%';
  $('equipo').value=5;$('equipoV').textContent='5%';
  $('minEnc').value=5;
  $('techo').value=3;$('techoV').textContent='3.0x';
  $('umbralDis').value=40;$('umbralDisV').textContent='40%';
  $('ahorroBen').value=30;$('ahorroBenV').textContent='30%';
