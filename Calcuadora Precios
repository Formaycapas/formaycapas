<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Calculadora de Precios — Forma y Capas</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Barlow:wght@400;500;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --orange:#E87722;--ol:#ff9940;
  --bg:#0d0d0d;--bg2:#141414;--bg3:#1a1a1a;
  --border:rgba(255,255,255,.08);
  --text:rgba(255,255,255,.85);--dim:rgba(255,255,255,.65);--faint:rgba(255,255,255,.55);
  --green:#4caf82;--blue:#5b9bd5;--yellow:#f0c040;
}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;padding:56px 20px 80px}
.topbar{position:fixed;top:0;left:0;right:0;height:5px;background:linear-gradient(90deg,var(--orange),var(--ol));z-index:200}
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(10px);background:var(--orange);color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:12px;letter-spacing:.15em;text-transform:uppercase;padding:10px 24px;opacity:0;transition:all .25s;pointer-events:none;z-index:999}
.toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
.wrap{max-width:700px;margin:0 auto}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;padding-bottom:18px;border-bottom:1px solid var(--border)}
.hdr-l{display:flex;align-items:center;gap:14px}
.ln{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;letter-spacing:.05em;text-transform:uppercase;line-height:1}
.ln .y{color:var(--orange)}
.ls{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.28em;color:var(--faint);text-transform:uppercase;margin-top:3px}
.hdr-r{text-align:right}
.ver{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.2em;color:rgba(255,255,255,.55);text-transform:uppercase}
.savebadge{display:inline-flex;align-items:center;gap:5px;font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.2em;color:var(--faint);text-transform:uppercase;transition:color .3s;margin-top:3px}
.savebadge.saved{color:rgba(100,220,100,.5)}
.sdot{width:5px;height:5px;border-radius:50%;background:currentColor}

h1{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:46px;text-transform:uppercase;line-height:.92;margin-bottom:6px}
h1 span{color:var(--orange)}
.sub{font-size:13px;color:var(--dim);margin-bottom:28px;line-height:1.6;max-width:560px}

/* SECCIONES */
.sec{background:var(--bg2);border:1px solid var(--border);padding:22px 24px;margin-bottom:10px}
.sec-title{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.35em;color:#ff7a1a;text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:8px}
.bdg{background:var(--orange);color:#000;font-size:9px;padding:2px 7px;font-weight:900;font-family:'Barlow Condensed',sans-serif}
.bdg.bl{background:var(--blue)}
.bdg.gr{background:var(--green)}

label{display:block;font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:6px}
.iw{position:relative}
input[type="number"],input[type="text"]{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:'Barlow',sans-serif;font-size:16px;font-weight:600;padding:11px 46px 11px 14px;outline:none;transition:border-color .2s,background .2s;-moz-appearance:textfield}
input[type="text"]{padding:11px 14px}
input[type="number"]::-webkit-outer-spin-button,input[type="number"]::-webkit-inner-spin-button{-webkit-appearance:none}
input:focus{border-color:var(--orange);background:rgba(232,119,34,.05)}
input[type="text"]::placeholder{color:var(--faint)}
.u{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-family:'Barlow Condensed',sans-serif;font-size:10px;color:var(--faint);text-transform:uppercase;pointer-events:none}
.hint{font-size:11px;color:rgba(255,255,255,.55);margin-top:5px;line-height:1.5}
.hint.bl{color:rgba(91,155,213,.85)}
.hint.gr{color:rgba(76,175,130,.85)}
.hint.or{color:rgba(232,119,34,.9)}
.fld{margin-bottom:14px}
.fld:last-child{margin-bottom:0}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.fixd{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);padding:11px 14px;font-size:16px;font-weight:600;color:rgba(255,255,255,.4);font-family:'Barlow',sans-serif}

/* MATERIALES */
.mat-hdrs{display:grid;grid-template-columns:1fr 108px 108px 40px;gap:8px;margin-bottom:8px}
.mh{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.2em;color:var(--faint);text-transform:uppercase;padding:0 3px}
.mat-list{display:flex;flex-direction:column;gap:8px}
.mat-row{display:grid;grid-template-columns:1fr 108px 108px 40px;gap:8px;align-items:center;animation:si .2s ease}
@keyframes si{from{opacity:0;transform:translateY(-5px)}to{opacity:1;transform:translateY(0)}}
.mat-row input[type="number"]{font-size:15px;padding:10px 38px 10px 12px}
.mat-row input[type="text"]{font-size:14px;padding:10px 12px}
.bdel{background:rgba(255,60,60,.08);border:1px solid rgba(255,60,60,.18);color:rgba(255,100,100,.45);font-size:19px;width:40px;height:40px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0}
.bdel:hover:not(:disabled){background:rgba(255,60,60,.22);color:#ff6666}
.bdel:disabled{opacity:.2;cursor:not-allowed}
.badd{background:transparent;border:1px dashed rgba(232,119,34,.35);color:rgba(232,119,34,.55);font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:.22em;text-transform:uppercase;padding:11px;cursor:pointer;width:100%;transition:all .2s;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:6px}
.badd:hover{border-color:var(--orange);color:var(--orange);background:rgba(232,119,34,.04)}
.mat-sub{display:flex;justify-content:flex-end;align-items:center;gap:8px;margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.ms-lbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.2em;color:rgba(255,255,255,.65);text-transform:uppercase}
.ms-val{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px}

/* SLIDER */
.sl-row{display:flex;align-items:center;gap:14px;margin-top:6px}
input[type="range"]{flex:1;-webkit-appearance:none;height:3px;background:rgba(255,255,255,.12);outline:none;cursor:pointer}
input[type="range"]::-webkit-slider-thumb{-webkit-appearance:none;width:18px;height:18px;background:var(--orange);cursor:pointer;border-radius:0}
.sl-val{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:22px;color:var(--orange);min-width:52px;text-align:right}

/* AVANZADO */
.adv-btn{width:100%;background:transparent;border:1px solid rgba(255,255,255,.07);color:var(--faint);font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.22em;text-transform:uppercase;padding:12px 18px;cursor:pointer;text-align:left;display:flex;justify-content:space-between;align-items:center;transition:all .2s;margin-bottom:10px}
.adv-btn:hover{border-color:rgba(232,119,34,.3);color:rgba(255,255,255,.5)}
.adv-btn .arr{transition:transform .3s;font-size:10px}
.adv-panel{display:none;background:rgba(255,255,255,.015);border:1px solid rgba(255,255,255,.055);padding:22px 24px;margin-bottom:10px}
.adv-grp{margin-bottom:20px;padding-bottom:20px;border-bottom:1px solid var(--border)}
.adv-grp:last-child{margin-bottom:0;padding-bottom:0;border-bottom:none}
.adv-grp-t{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.3em;color:rgba(255,255,255,.6);text-transform:uppercase;margin-bottom:12px}
.ibox{background:rgba(232,119,34,.05);border-left:3px solid rgba(232,119,34,.35);padding:10px 14px;margin-top:10px;font-size:11.5px;line-height:1.65;color:rgba(255,255,255,.75)}
.ibox strong{color:var(--orange)}
.ibox.bl{background:rgba(91,155,213,.07);border-left-color:rgba(91,155,213,.5)}
.ibox.bl strong{color:var(--blue)}
.ibox.gr{background:rgba(76,175,130,.07);border-left-color:rgba(76,175,130,.5)}
.ibox.gr strong{color:var(--green)}
.aviso{background:rgba(255,180,0,.06);border:1px solid rgba(255,180,0,.2);padding:10px 14px;font-size:12px;color:rgba(255,180,0,.8);font-family:'Barlow Condensed',sans-serif;display:none;margin-top:8px;line-height:1.5}

/* RESULTADO */
.res{background:rgba(232,119,34,.07);border:2px solid var(--orange);padding:28px 24px;margin-bottom:10px}
.res-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:22px;flex-wrap:wrap;gap:12px}
.p-lbl{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.35em;color:rgba(255,255,255,.4);text-transform:uppercase;margin-bottom:2px}
.p-final{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:82px;color:var(--orange);line-height:1}
.p-final.minimo{color:var(--yellow)}
.p-sub{font-family:'Barlow Condensed',sans-serif;font-size:12px;color:rgba(255,255,255,.65);margin-top:6px}
.badges{display:flex;flex-direction:column;align-items:flex-end;gap:6px;padding-top:6px}
.pb{font-family:'Barlow Condensed',sans-serif;font-size:11px;letter-spacing:.08em;padding:5px 11px;border:1px solid;white-space:nowrap;text-transform:uppercase}
.pb.gas{color:rgba(232,119,34,.8);border-color:rgba(232,119,34,.25);background:rgba(232,119,34,.05)}
.pb.res2{color:rgba(91,155,213,.8);border-color:rgba(91,155,213,.25);background:rgba(91,155,213,.05)}
.pb.ben{color:rgba(76,175,130,.9);border-color:rgba(76,175,130,.3);background:rgba(76,175,130,.06)}
.pb.min{color:var(--yellow);border-color:rgba(240,192,64,.3);background:rgba(240,192,64,.05)}

/* BLOQUES CATEGORÍA */
.cats{display:flex;flex-direction:column;gap:8px;margin-bottom:16px}
.cat{border:1px solid var(--border);overflow:hidden}
.cat-h{display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(0,0,0,.2)}
.cdot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.cname{font-family:'Barlow Condensed',sans-serif;font-size:9.5px;letter-spacing:.28em;text-transform:uppercase;flex:1}
.ctot{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px}
.cpct{font-family:'Barlow Condensed',sans-serif;font-size:11px;color:var(--faint);margin-left:6px}
.cdesc{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.1em;color:rgba(255,255,255,.55);text-transform:uppercase;margin-left:auto;padding-right:4px}
.citems{display:grid;gap:1px;background:rgba(255,255,255,.04)}
.ci2{grid-template-columns:1fr 1fr}
.ci3{grid-template-columns:1fr 1fr 1fr}
.ci{background:var(--bg2);padding:11px 14px}
.ci-l{font-family:'Barlow Condensed',sans-serif;font-size:8.5px;letter-spacing:.18em;color:rgba(255,255,255,.6);text-transform:uppercase;margin-bottom:4px}
.ci-v{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:16px}
.ci-p{font-size:9.5px;color:rgba(255,255,255,.5);font-family:'Barlow Condensed',sans-serif;margin-top:2px}

/* COLORES CATEGORÍAS */
.c-gas .cdot,.c-gas .cname,.c-gas .ctot{color:var(--orange)}
.c-gas .cdot{background:var(--orange)}.c-gas .ci-v{color:#fff}
.c-res .cdot{background:var(--blue)}.c-res .cname,.c-res .ctot{color:var(--blue)}.c-res .ci-v{color:var(--blue)}
.c-ben .cdot{background:var(--green)}.c-ben .cname,.c-ben .ctot{color:var(--green)}.c-ben .ci-v{color:var(--green)}

/* SUBTOTAL BENEFICIO (bruto - ahorro = neto) */
.ben-subtotal{background:rgba(76,175,130,.04);padding:10px 14px;display:flex;flex-direction:column;gap:4px;border-top:1px solid var(--border)}
.bs-row{display:flex;justify-content:space-between;align-items:center;font-family:'Barlow Condensed',sans-serif}
.bs-row .bs-lbl{font-size:10px;letter-spacing:.18em;color:rgba(255,255,255,.55);text-transform:uppercase}
.bs-row .bs-val{font-weight:700;font-size:15px;color:rgba(255,255,255,.85)}
.bs-row.negative .bs-lbl{color:rgba(91,155,213,.85)}
.bs-row.negative .bs-val{color:rgba(91,155,213,.85)}
.bs-row.total{padding-top:6px;border-top:1px dashed rgba(255,255,255,.1);margin-top:2px}
.bs-row.total .bs-lbl{color:var(--green);font-weight:700}
.bs-row.total .bs-val{color:var(--green);font-size:18px;font-weight:900}

/* BARRAS */
.barras{margin-bottom:16px}
.br{display:flex;align-items:center;gap:10px;margin-bottom:7px}
.br-l{font-family:'Barlow Condensed',sans-serif;font-size:9px;letter-spacing:.1em;color:rgba(255,255,255,.7);text-transform:uppercase;width:105px;flex-shrink:0}
.b{flex:1;height:5px;background:rgba(255,255,255,.07);overflow:hidden}
.bf{height:100%;transition:width .4s cubic-bezier(.4,0,.2,1)}
.bf.or{background:linear-gradient(90deg,#E87722,#ff9940)}
.bf.bl{background:linear-gradient(90deg,#5b9bd5,#7bb8f0)}
.bf.gr{background:linear-gradient(90deg,#4caf82,#70d0a0)}
.br-n{font-family:'Barlow Condensed',sans-serif;font-size:10px;color:rgba(255,255,255,.65);width:34px;text-align:right;flex-shrink:0}

.pmin{background:rgba(0,0,0,.35);border:1px solid rgba(255,255,255,.07);padding:12px 16px;display:flex;justify-content:space-between;align-items:center}
.pm-l{font-family:'Barlow Condensed',sans-serif;font-size:9.5px;letter-spacing:.18em;color:rgba(255,255,255,.65);text-transform:uppercase}
.pm-v{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:18px;color:rgba(255,255,255,.85)}

/* BOTONES */
.btn-pres{width:100%;background:var(--orange);border:none;color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:16px;letter-spacing:.15em;text-transform:uppercase;padding:18px;cursor:pointer;transition:all .2s;margin-top:10px;display:flex;align-items:center;justify-content:center;gap:10px}
.btn-pres:hover{background:var(--ol);transform:translateY(-1px)}
.btn-rst{width:100%;background:transparent;border:1px solid rgba(255,255,255,.09);color:rgba(255,255,255,.28);font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.22em;text-transform:uppercase;padding:12px;cursor:pointer;transition:all .2s;margin-top:8px}
.btn-rst:hover{border-color:rgba(255,80,80,.4);color:rgba(255,100,100,.6)}
.fnote{text-align:center;font-size:11px;color:rgba(255,255,255,.5);margin-top:20px;line-height:1.6}

/* MODAL */
.modal-ov{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.modal-ov.open{display:flex}
.modal{background:#181818;border:1px solid rgba(255,255,255,.12);width:100%;max-width:600px;max-height:90vh;overflow-y:auto;animation:mi .25s ease}
@keyframes mi{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
.m-hdr{display:flex;align-items:center;justify-content:space-between;padding:20px 24px;border-bottom:1px solid var(--border);background:rgba(232,119,34,.06)}
.m-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:20px;letter-spacing:.05em;text-transform:uppercase;color:var(--orange)}
.m-close{background:transparent;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);font-size:20px;width:36px;height:36px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .2s}
.m-close:hover{border-color:rgba(255,80,80,.4);color:#ff6666}
.m-body{padding:24px}
.mg{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.mf{margin-bottom:16px}
.mf label{display:block;font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:rgba(255,255,255,.7);margin-bottom:6px}
.mf input,.mf textarea{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,.1);color:#fff;font-family:'Barlow',sans-serif;font-size:15px;font-weight:500;padding:10px 14px;outline:none;transition:border-color .2s;resize:vertical}
.mf input:focus,.mf textarea:focus{border-color:var(--orange)}
.mf textarea{min-height:72px;line-height:1.5}
.mf input::placeholder,.mf textarea::placeholder{color:var(--faint)}
.m-prev{background:rgba(232,119,34,.08);border:1px solid rgba(232,119,34,.3);padding:16px 20px;margin-top:6px;display:flex;align-items:center;gap:16px;flex-wrap:wrap}
.mp-l{font-family:'Barlow Condensed',sans-serif;font-size:10px;letter-spacing:.25em;color:rgba(255,255,255,.4);text-transform:uppercase;flex:1;min-width:120px}
.mp-v{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:40px;color:var(--orange);line-height:1}
.mp-s{font-family:'Barlow Condensed',sans-serif;font-size:11px;color:rgba(255,255,255,.3);width:100%;margin-top:4px}
.m-ftr{padding:16px 24px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end}
.btn-cancel{background:transparent;border:1px solid rgba(255,255,255,.1);color:rgba(255,255,255,.4);font-family:'Barlow Condensed',sans-serif;font-size:12px;letter-spacing:.15em;text-transform:uppercase;padding:11px 20px;cursor:pointer;transition:all .2s}
.btn-cancel:hover{border-color:rgba(255,255,255,.25);color:rgba(255,255,255,.7)}
.btn-gen{background:var(--orange);border:none;color:#000;font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:13px;letter-spacing:.15em;text-transform:uppercase;padding:11px 28px;cursor:pointer;transition:all .2s;display:flex;align-items:center;gap:8px}
.btn-gen:hover{background:var(--ol)}

/* BOTÓN FLOTANTE CONFIG */
.fab-config{position:fixed;top:18px;right:18px;width:40px;height:40px;background:rgba(232,119,34,.7);border:1px solid rgba(232,119,34,.4);color:#000;font-size:18px;cursor:pointer;z-index:300;transition:all .2s;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(8px);border-radius:50%;box-shadow:0 2px 8px rgba(0,0,0,.4);opacity:.7}
.fab-config:hover{opacity:1;background:var(--orange);transform:rotate(45deg)}
@media(max-width:560px){.fab-config{top:14px;right:14px;width:36px;height:36px;font-size:16px}}
@media(max-width:560px){
  .mat-row,.mat-hdrs{grid-template-columns:1fr 85px 85px 36px}
  .p-final{font-size:58px}.g2,.g3{grid-template-columns:1fr}
  .res-top{flex-direction:column}.badges{align-items:flex-start}
  .citems.ci2,.citems.ci3{grid-template-columns:1fr 1fr}
  .mg{grid-template-columns:1fr}
}
</style>
</head>
<body>
<div class="topbar"></div>
<div class="toast" id="toast"></div>

<div class="wrap">
  <div class="hdr">
    <div class="hdr-l">
      <svg width="40" height="40" viewBox="0 0 52 52" xmlns="http://www.w3.org/2000/svg">
        <polygon points="26,4 48,16 26,28 4,16" fill="#ffaa55"/>
        <polygon points="4,16 26,28 26,48 4,36" fill="#E87722"/>
        <polygon points="26,28 48,16 48,36 26,48" fill="#a84d00"/>
      </svg>
      <div><div class="ln">FORMA <span class="y">Y</span> CAPAS</div><div class="ls">Impresión 3D · Valencia</div></div>
    </div>
    <div class="hdr-r">
      <div class="ver">Calculadora v4.8 arranque</div>
      <div class="savebadge" id="saveBadge"><span class="sdot"></span><span id="saveTxt">Guardando...</span></div>
    </div>
  </div>

  <h1>CALCULA TU <span>PRECIO</span></h1>
  <p class="sub">Mete los materiales y el tiempo. El precio se divide en <span style="color:var(--orange)">gastos</span>, <span style="color:var(--blue)">reservas</span> y <span style="color:var(--green)">beneficio real</span>.</p>

  <!-- 01 MATERIALES -->
  <div class="sec">
    <div class="sec-title"><span class="bdg">01</span> Materiales · <span style="color:var(--orange);margin-left:4px">gasto directo</span></div>
    <div class="mat-hdrs">
      <div class="mh">Material / descripción</div>
      <div class="mh" style="text-align:center">€ rollo 1kg</div>
      <div class="mh" style="text-align:center">Gramos usados</div>
      <div class="mh"></div>
    </div>
    <div class="mat-list" id="matList"></div>
    <button class="badd" onclick="addMat()"><span style="font-size:15px">+</span> Añadir material</button>
    <div class="mat-sub">
      <span class="ms-lbl">Total filamento</span>
      <span class="ms-val" style="color:var(--orange)" id="matSub">0,00 €</span>
    </div>
