// ── MODAL PRESUPUESTO ─────────────────────────────────────
function abrirModal(){
  if(_precio<=0){toast('Calcula el precio primero');return}
  const mats=[];
  document.querySelectorAll('.mat-row').forEach(r=>{
    const n=r.querySelector('.mn').value||'Material';
    const g=r.querySelector('.mg2').value;
    mats.push(n+(g?` (${g}g)`:''));
  });
  $('pMat').value=mats.join(', ');
  $('mpV').textContent=$('pFinal').textContent;
  $('mpS').textContent=_dis>0?`Incluye ${fmt(_dis)} de diseño`:'';
  $('modalOv').classList.add('open');
}
function cerrarModal(){$('modalOv').classList.remove('open')}
function cerrarModalClick(e){if(e.target===$('modalOv'))cerrarModal()}

